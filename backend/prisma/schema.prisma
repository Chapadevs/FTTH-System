datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  // Avoid Windows EPERM on query_engine rename in hoisted node_modules/.prisma (OneDrive / file locks)
  output   = "../src/generated/prisma"
}

model User {
  id          String    @id @default(cuid())
  firebaseUid String    @unique
  username    String?   @unique
  passwordHash String?
  email       String    @unique
  name        String
  role        Role      @default(FIELD_TECH)
  createdAt   DateTime  @default(now())
  projects    Project[]
}

model Project {
  id             String        @id @default(cuid())
  prismId        String
  name           String
  node           String
  instance       String
  status         ProjectStatus @default(PENDING)
  totalPassings  Int           @default(0)
  sourceFilePath String?
  importMetadata Json?
  createdAt      DateTime      @default(now())
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])
  poles          Pole[]
  equipment      Equipment[]
  segments       FiberSegment[]
  sheaths        Sheath[]
}

model Pole {
  id               String            @id @default(cuid())
  poleNumber       String
  lat              Float
  lng              Float
  streetName       String?
  status           PoleStatus         @default(PLANNED)
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  segmentsFrom     FiberSegment[]     @relation("FromPole")
  segmentsTo       FiberSegment[]     @relation("ToPole")
  equipment        Equipment[]
  sheathEndpoints  SheathEndpoint[]
  fiberObservations FiberEndpointObservation[]
}

model FiberSegment {
  id         String  @id @default(cuid())
  lengthFt   Float
  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromPoleId String
  fromPole   Pole    @relation("FromPole", fields: [fromPoleId], references: [id])
  toPoleId   String
  toPole     Pole    @relation("ToPole", fields: [toPoleId], references: [id])
}

model Equipment {
  id              String           @id @default(cuid())
  tag             String
  name            String
  manufacturer    String
  model           String
  equipType       EquipType
  portCount       Int?
  poleId          String
  pole            Pole             @relation(fields: [poleId], references: [id])
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fiberAssignments FiberAssignment[]
}

model Sheath {
  id           String          @id @default(cuid())
  name         String
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  endpoints    SheathEndpoint[]
  fiberRecords FiberRecord[]

  @@index([projectId])
}

model SheathEndpoint {
  id        String        @id @default(cuid())
  sheathId  String
  sheath    Sheath        @relation(fields: [sheathId], references: [id], onDelete: Cascade)
  poleId    String
  pole      Pole          @relation(fields: [poleId], references: [id])
  role      EndpointRole
  createdAt DateTime      @default(now())

  @@unique([sheathId, poleId, role])
  @@index([sheathId])
  @@index([poleId])
}

model FiberRecord {
  id              String           @id @default(cuid())
  sheathId        String
  sheath          Sheath           @relation(fields: [sheathId], references: [id], onDelete: Cascade)
  bufferColor     FiberColor
  fiberColor      FiberColor
  bufferIndex     Int
  fiberIndex      Int
  direction       FiberDirection?
  wavelength      Float?
  connectionType  ConnectionType
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignments     FiberAssignment[]
  endpointObservations FiberEndpointObservation[]

  @@unique([sheathId, bufferIndex, fiberIndex])
  @@index([sheathId])
}

model FiberAssignment {
  id            String           @id @default(cuid())
  fiberRecordId String
  fiberRecord   FiberRecord      @relation(fields: [fiberRecordId], references: [id], onDelete: Cascade)
  equipmentId   String?
  equipment     Equipment?       @relation(fields: [equipmentId], references: [id])
  deviceName    String?
  portName      String?
  status        AssignmentStatus
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([fiberRecordId])
  @@index([equipmentId])
}

model FiberEndpointObservation {
  id             String                   @id @default(cuid())
  fiberRecordId  String
  fiberRecord    FiberRecord              @relation(fields: [fiberRecordId], references: [id], onDelete: Cascade)
  poleId         String
  pole           Pole                     @relation(fields: [poleId], references: [id])
  role           EndpointRole
  connectionType ConnectionType
  rawConnection  String?
  wavelength     Float?
  deviceName     String?
  portName       String?
  state          EndpointObservationState
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([fiberRecordId, poleId])
  @@index([fiberRecordId])
  @@index([poleId])
  @@index([poleId, state])
}

enum EndpointRole {
  START
  END
}

enum FiberColor {
  BLUE
  ORANGE
  GREEN
  BROWN
  SLATE
  WHITE
  RED
  BLACK
  YELLOW
  VIOLET
  PINK
  AQUA
}

enum FiberDirection {
  FORWARD
  RETURN
}

enum ConnectionType {
  FUSION
  MECHANICAL
  DARK
}

enum AssignmentStatus {
  ACTIVE
  DARK
  INCONSISTENT
}

enum EndpointObservationState {
  ACTIVE
  DARK
  NEEDS_FUSION
}

enum Role {
  ADMIN
  MANAGER
  FIELD_TECH
}
enum ProjectStatus {
  PENDING
  PROCESSING
  ACTIVE
  ARCHIVED
}
enum PoleStatus {
  PLANNED
  ACTIVE
  DECOMMISSIONED
}
enum EquipType {
  SPLITTER
  TERMINATION
}
