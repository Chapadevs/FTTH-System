DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fiberops
# Mock login only when BOTH NODE_ENV=development and ALLOW_DEV_AUTH_MOCK=true (npm run dev sets both).
# Production: NODE_ENV=production and do NOT set ALLOW_DEV_AUTH_MOCK.
NODE_ENV=
ALLOW_DEV_AUTH_MOCK=
PORT=3000
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_INITIAL_PASSWORD=
GCS_BUCKET_IMPORTS=fiberops-imports
GCS_BUCKET_PHOTOS=fiberops-photos
GCP_PROJECT_ID=
# Imports: local disk (default when NODE_ENV is not production) or GCS. Set false to force signed GCS URLs.
IMPORT_LOCAL_STORAGE=
# Street routing provider (OSRM-compatible). Defaults to the public OSRM demo if empty.
ROUTING_BASE_URL=
# Signed upload URLs need a service account key (user ADC from gcloud cannot sign).
# Option A: path to a JSON key file
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: raw JSON (e.g. in CI / Cloud Run)
GCP_SERVICE_ACCOUNT_KEY_JSON=
